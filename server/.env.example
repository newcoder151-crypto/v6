# PostgreSQL (mNVR database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mnvr
DB_USER=mnvr
DB_PASSWORD=mnvr

# JWT
JWT_SECRET=change-me-long-random-secret-in-production

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:8080

# Python YOLO sidecar URL
YOLO_SIDECAR_URL=http://localhost:8000

# Storage paths (must match mNVR C process output)
STORAGE_PATH=./storage
RECORDINGS_PATH=./storage/recordings
HLS_PATH=./storage/hls

# Server port
PORT=3001
NODE_ENV=development
NVR_CORE_URL=http://localhost:8080
